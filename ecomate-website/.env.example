# ─────────────────────────────────────────────────────────────────
# ECOMATE — Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to Git!
# ─────────────────────────────────────────────────────────────────

# ── SUPABASE ──────────────────────────────────────────────────────
# Get from: https://supabase.com → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE

# Server-only (NEVER expose to client. Keep secret!)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# ── APP CONFIG ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app
NEXT_PUBLIC_ADMIN_SECRET_PATH=em-admin-entrance-x9k7

# ── EMAIL — Resend ────────────────────────────────────────────────
# Get from: https://resend.com
RESEND_API_KEY=re_YOUR_RESEND_API_KEY

# ── PAYMENTS — Chargily Pay V2 ────────────────────────────────────
# Get from: https://pay.chargily.net/test/dashboard
# Use test key for development, live key for production
CHARGILY_SECRET_KEY=

# ── WEBHOOKS ─────────────────────────────────────────────────────
WEBHOOK_SECRET=your_webhook_secret_here

# ── ANALYTICS — Google Analytics (optional) ──────────────────────
# GA_ID=G-XXXXXXXXXX
